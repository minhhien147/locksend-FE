# Sao chép thành .env.local (dev)
# Local backend (uvicorn --port 8000):
VITE_API_URL=/api

# Hoặc gọi thẳng (cần ALLOWED_ORIGINS có http://localhost:5173 trong backend/.env):
# VITE_API_URL=http://localhost:8000

# Tuỳ chọn — cùng giá trị GOOGLE_CLIENT_ID trong backend/.env
# (nếu bỏ trống, frontend tự lấy qua GET /auth/google/config)
VITE_GOOGLE_CLIENT_ID=
