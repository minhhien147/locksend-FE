# ╔══════════════════════════════════════════════════════════════════╗
# ║       LockSend Frontend — Environment Variables                 ║
# ║  Sao chép thành .env.local (dev) / đặt trong Railway Variables  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── API URL ────────────────────────────────────────────────────────────────────
# Dev qua Vite proxy (vite.config.ts → proxy /api → :8000):
VITE_API_URL=/api

# Hoặc gọi thẳng (cần ALLOWED_ORIGINS có http://localhost:5173 trong backend/.env):
# VITE_API_URL=http://localhost:8000

# Production (Railway / Azure Static Web Apps build-time variable):
# VITE_API_URL=https://your-backend.up.railway.app

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Tuỳ chọn: nếu bỏ trống, frontend tự lấy qua GET /auth/google/config.
# Phải khớp với GOOGLE_CLIENT_ID trong backend/.env.
VITE_GOOGLE_CLIENT_ID=
